{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "extrachill/trivia",
   "version": "1.1.1",
  "title": "Trivia Question",
  "category": "widgets",
  "icon": "lightbulb",
  "description": "Create interactive trivia questions with multiple choice answers and automatic scoring.",
  "keywords": [
    "trivia",
    "quiz",
    "question",
    "interactive",
    "education"
  ],
  "supports": {
    "html": false,
    "anchor": true,
    "customClassName": true
  },
  "attributes": {
    "question": {
      "type": "string",
      "default": ""
    },
    "options": {
      "type": "array",
      "default": ["", ""]
    },
    "correctAnswer": {
      "type": "number",
      "default": 0
    },
    "answerJustification": {
      "type": "string",
      "default": ""
    },
    "blockId": {
      "type": "string",
      "default": ""
    },
    "resultMessages": {
      "type": "object",
      "default": {
        "excellent": "🏆 Trivia Master!",
        "good": "🎉 Great Job!",
        "okay": "👍 Not Bad!",
        "poor": "🤔 Keep Trying!"
      }
    },
    "scoreRanges": {
      "type": "object",
      "default": {
        "excellent": 90,
        "good": 70,
        "okay": 50
      }
    }
  },
  "textdomain": "extrachill-content-blocks",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "viewScript": "file:./view.js",
  "render": "file:./render.php"
}